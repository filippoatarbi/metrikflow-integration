<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <pipeline_version/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>RUNTIME_DIR</name>
        <description>Runtime root directory</description>
        <default_value>C:/Users/filippoc/Documents/Sviluppo/metrikflow-integration/runtime</default_value>
      </parameter>
    </parameters>
    <name>hello-hop</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/07/15 15:51:03.126</created_date>
    <modified_date>2026/07/15 15:51:03.126</modified_date>
  </info>
  <transform>
    <type>RowGenerator</type>
    <name>Generate rows</name>
    <never_ending>N</never_ending>
    <interval_in_ms>5000</interval_in_ms>
    <row_time_field>now</row_time_field>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <fields>
      <field>
        <name>message</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif>Hello from Apache Hop</nullif>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <name>project</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif>metrikflow</nullif>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <name>status</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif>OK</nullif>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>224</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TextFileOutput</type>
    <name>Text file output</name>
    <compression>None</compression>
    <create_parent_folder>Y</create_parent_folder>
    <separator>;</separator>
    <enclosure>"</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>Y</enclosure_fix_disabled>
    <header>Y</header>
    <footer>N</footer>
    <format>DOS</format>
    <encoding>UTF-8</encoding>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <schema_definition/>
    <ignore_fields>N</ignore_fields>
    <file>
      <name>${RUNTIME_DIR}/output/hello-hop</name>
      <do_not_open_new_file_init>Y</do_not_open_new_file_init>
      <extension>csv</extension>
      <append>N</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
      <splitevery/>
    </file>
    <fields>
      <field>
        <name>message</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif/>
        <trim_type>none</trim_type>
        <roundingType>half_even</roundingType>
      </field>
      <field>
        <name>project</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif/>
        <trim_type>none</trim_type>
        <roundingType>half_even</roundingType>
      </field>
      <field>
        <name>status</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif/>
        <trim_type>none</trim_type>
        <roundingType>half_even</roundingType>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>432</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Generate rows</from>
      <to>Text file output</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
