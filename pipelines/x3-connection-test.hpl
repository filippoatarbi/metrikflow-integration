        <decimal/>
        <group/>
        <nullif/>
        <trim_type>none</trim_type>
        <roundingType>half_even</roundingType>
      </field>
      <field>
        <name>login_name</name>
        <type>String</type>
        <format/>
        <length>128</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif/>
        <trim_type>none</trim_type>
        <roundingType>half_even</roundingType>
      </field>
      <field>
        <name>server_time</name>
        <type>Timestamp</type>
        <format/>
        <length>3</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <nullif/>
        <trim_type>none</trim_type>
        <roundingType>half_even</roundingType>
      </field>
      <field>
